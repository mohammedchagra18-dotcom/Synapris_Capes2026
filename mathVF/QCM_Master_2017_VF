    for(let i=11; i<=60; i++) {
      if(i===11) questionsData.push({ id: 11, statement: "Dans le plan rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j})$, on donne les droites $\\Delta : x - y = 1$ et $\\Delta' : x + y = 1$. Une équation de $\\Delta \\cup \\Delta'$ est :", choices: ["$x^2 - y^2 = 1$", "$y = |x-1|$", "$|y| = |x| + 1$", "$(x + y - 1)(x - y - 1) = 0$"], correct: 3, theme: "Géométrie plane", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nL'union de deux droites $L_1=0$ et $L_2=0$ a pour équation $L_1 \\times L_2 = 0$. $\\Delta : x-y-1=0$, $\\Delta' : x+y-1=0$. Le produit $(x-y-1)(x+y-1)=0$.\n\n⚠️ VIGILANCE : $(x-y-1)(x+y-1) = x^2 - y^2 - 2x + 1 = 0$, pas $x^2-y^2=1$.\n\n💡 ASTUCE : Une réunion de courbes $f=0$ et $g=0$ a pour équation $f \\cdot g = 0$." });
      else if(i===12) questionsData.push({ id: 12, statement: "Dans le plan orienté, on considère un carré $ABCD$ direct de centre $O$. On note $I$ le milieu de $[AB]$, $J$ le milieu de $[BC]$. On donne $f = S_{(AB)} \\circ t_{\\overrightarrow{BC}}$.", choices: ["$f$ est la symétrie glissante d'axe $(AB)$ et de vecteur $\\overrightarrow{BC}$", "$f$ est la symétrie orthogonale d'axe $\\Delta = S_{(AB)}((OJ))$", "$f$ est la symétrie orthogonale d'axe $(OJ)$", "$f = t_{\\overrightarrow{BC}} \\circ S_{(AB)}$"], correct: 1, theme: "Isométries — Composition", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$S_{(AB)} \\circ t_{\\overrightarrow{BC}}$ est un antidéplacement. La composée d'une symétrie et d'une translation perpendiculaire à l'axe est une symétrie orthogonale d'axe translaté. L'axe est $\\Delta = S_{(AB)}((OJ))$.\n\n⚠️ VIGILANCE : $\\overrightarrow{BC} \\perp (AB)$, donc c'est une symétrie orthogonale, pas glissante.\n\n💡 ASTUCE : $S \\circ t$ donne une symétrie orthogonale si le vecteur est orthogonal à l'axe." });
      else if(i===13) questionsData.push({ id: 13, statement: "On pose $g = S_O \\circ S_{(AC)}$.", choices: ["$g$ est la symétrie orthogonale d'axe $(OJ)$", "$g$ est une symétrie glissante", "$g$ est la symétrie orthogonale d'axe $(BD)$", "$g$ conserve les mesures des angles orientés"], correct: 2, theme: "Isométries — Composition", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$S_O = S_{(BD)} \\circ S_{(AC)}$ car $(BD) \\perp (AC)$ en $O$. Donc $g = S_{(BD)} \\circ S_{(AC)} \\circ S_{(AC)} = S_{(BD)}$. C'est une symétrie orthogonale d'axe $(BD)$.\n\n⚠️ VIGILANCE : $S_O = S_{D_1} \\circ S_{D_2}$ pour deux droites perpendiculaires passant par $O$.\n\n💡 ASTUCE : Utiliser la décomposition d'une symétrie centrale en produit de deux symétries orthogonales." });
      else if(i===14) questionsData.push({ id: 14, statement: "On donne $h = S_{(AB)} \\circ S_{(DC)}$.", choices: ["$h = t_{2\\overrightarrow{BC}}$", "$h = t_{2\\overrightarrow{CB}}$", "$h$ est une homothétie", "$h((AB)) = (AB)$"], correct: 1, theme: "Isométries — Composition", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$(AB)$ et $(DC)$ sont parallèles. La composée de deux symétries orthogonales d'axes parallèles est une translation de vecteur $2\\overrightarrow{CB}$ (de $(DC)$ vers $(AB)$).\n\n⚠️ VIGILANCE : L'ordre des symétries compte : $S_{D_1} \\circ S_{D_2} = t_{2\\vec{u}}$ où $\\vec{u}$ va de $D_2$ vers $D_1$.\n\n💡 ASTUCE : Pour des axes parallèles, $S_{D_1} \\circ S_{D_2}$ est une translation." });
      else if(i===15) questionsData.push({ id: 15, statement: "On donne l'application $\\psi = S_{(AB)} \\circ S_O$.", choices: ["$\\psi$ est une symétrie centrale", "$\\psi = S_{(OJ)} \\circ S_{(IO)}$", "$\\psi = S_{(OI)} \\circ t_{\\overrightarrow{CB}}$", "$\\psi = t_{2\\overrightarrow{CB}} \\circ S_{(OI)}$"], correct: 1, theme: "Isométries — Décomposition", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$S_O = S_{(OI)} \\circ S_{(OJ)}$ (car $(OI) \\perp (OJ)$). Donc $\\psi = S_{(AB)} \\circ S_{(OI)} \\circ S_{(OJ)}$. Comme $(AB) \\parallel (OI)$, on simplifie pour obtenir $\\psi = S_{(OJ)} \\circ S_{(IO)}$.\n\n⚠️ VIGILANCE : La décomposition de $S_O$ dépend du choix des axes perpendiculaires.\n\n💡 ASTUCE : $S_O = S_D \\circ S_{D'}$ pour toutes droites perpendiculaires $D$ et $D'$ passant par $O$." }); 
      else if(i===16) questionsData.push({ id: 16, statement: "Soit $r$ la rotation de centre $O$ qui transforme $A$ en $B$. On considère l'application $f$ dans le plan qui à tout point $M$ associe le point $M'$ tel que $M'$ est le milieu du segment d'extrémités $M$ et $r(M)$.", choices: ["$f$ est un déplacement d'angle $\\dfrac{\\pi}{4}$", "$f$ est une symétrie centrale", "$f$ est une similitude directe", "$f$ est une similitude indirecte de centre $O$"], correct: 2, theme: "Similitudes", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$r$ est la rotation de centre $O$ d'angle $\\pi/2$. $f(M) = \\frac{M + r(M)}{2}$. En complexes, $f(z) = \\frac{z + i z}{2} = \\frac{1+i}{2}z$, similitud      directe de rapport $\\frac{\\sqrt{2}}{2}$ et d'angle $\\pi/4$.\n\n⚠️ VIGILANCE : Le milieu de $M$ et $r(M)$ décrit une similitude, pas une isométrie.\n\n💡 ASTUCE : $f(z) = \\frac{z+iz}{2} = \\frac{1+i}{2}z$.\n\n🎯 OBJECTIF : Reconnaître une similitude à partir d'une construction géométrique." });
      else if(i===17) questionsData.push({ id: 17, statement: "Dans le plan rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j})$, on donne $\\mathscr{H} : xy = 1$ et $\\mathscr{E} : x^2 + y^2 = 1$.", choices: ["$\\mathscr{H} \\cap \\mathscr{E} = \\{(1,1),(-1,-1)\\}$", "$\\mathscr{H} \\cap \\mathscr{E} = \\left\\{\\left(\\dfrac{1}{\\sqrt{2}},\\sqrt{2}\\right), \\left(\\dfrac{1}{\\sqrt{2}},-\\sqrt{2}\\right)\\right\\}$", "$\\mathscr{H} \\cap \\mathscr{E} = \\left\\{\\left(\\sqrt{2},\\dfrac{1}{\\sqrt{2}}\\right), \\left(-\\sqrt{2},\\dfrac{-1}{\\sqrt{2}}\\right)\\right\\}$", "$\\mathscr{H} \\cap \\mathscr{E} = \\emptyset$"], correct: 3, theme: "Coniques — Intersection", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$xy=1$ et $x^2+y^2=1$. Substituons $y=1/x$ : $x^2 + 1/x^2 = 1$, soit $x^4 - x^2 + 1 = 0$. Posons $X=x^2$ : $X^2-X+1=0$, $\\Delta=1-4=-3<0$. Pas de solution réelle. $\\mathscr{H} \\cap \\mathscr{E} = \\emptyset$.\n\n⚠️ VIGILANCE : $x^2+1/x^2 \\ge 2$ par l'inégalité $a+1/a \\ge 2$ pour $a>0$, donc $x^2+1/x^2=1$ impossible.\n\n💡 ASTUCE : Résoudre algébriquement l'intersection." });
      else if(i===18) questionsData.push({ id: 18, statement: "Si $A$, $B$ et $C$ sont trois points non alignés du plan et $I$ est le milieu de $[BC]$ alors :", choices: ["les triangles $AIB$ et $AIC$ sont isométriques", "$\\overrightarrow{AI} \\cdot \\overrightarrow{AB} = \\overrightarrow{AI} \\cdot \\overrightarrow{AC}$", "$AI^2 = \\dfrac{1}{2}\\left(AB^2 + AC^2 + 2AB \\times AC \\cos(\\widehat{BAC})\\right)$", "les triangles $AIB$ et $AIC$ ont la même aire"], correct: 3, theme: "Géométrie plane — Médiane", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nLes triangles $AIB$ et $AIC$ ont même hauteur issue de $A$ et des bases $IB$ et $IC$ égales (car $I$ milieu). Donc ils ont la même aire.\n\n⚠️ VIGILANCE : La formule de la médiane est $AI^2 = \\frac{1}{2}(AB^2+AC^2)-\\frac{BC^2}{4}$.\n\n💡 ASTUCE : Deux triangles de même hauteur et bases égales ont même aire." });
      else if(i===19) questionsData.push({ id: 19, statement: "Si $ABC$ est un triangle rectangle en $A$ et $H$ est le projeté orthogonal de $A$ sur $(BC)$ alors :", choices: ["$AH \\times BC = AC^2$", "$AC \\times AB = AH^2$", "$HB \\times HC = AH^2$", "$AH \\times BC = AB^2$"], correct: 2, theme: "Géométrie plane — Triangle rectangle", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\nDans un triangle rectangle, la hauteur relative à l'hypoténuse vérifie $AH^2 = HB \\times HC$ (relation métrique classique).\n\n⚠️ VIGILANCE : $AH \\times BC = AB \\times AC$ (double de l'aire).\n\n💡 ASTUCE : Les trois triangles $ABC$, $HBA$, $HAC$ sont semblables." });
      else if(i===20) questionsData.push({ id: 20, statement: "Dans le plan rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j})$, on donne $\\mathscr{C} : x^2 + y^2 = 1$ et $\\Gamma : (x-3)^2 + (y-4)^2 = 16$.", choices: ["$\\mathscr{C} \\cap \\Gamma = \\emptyset$", "$\\mathscr{C}$ et $\\Gamma$ sont tangents intérieurement", "$\\mathscr{C}$ et $\\Gamma$ sont tangents extérieurement", "$\\mathscr{C}$ et $\\Gamma$ sont tangents à la droite d'équation $y = x + 2$"], correct: 2, theme: "Géométrie plane — Cercles", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$\\mathscr{C}$ : centre $O(0,0)$, rayon $R=1$. $\\Gamma$ : centre $\\Omega(3,4)$, rayon $r=4$. $O\\Omega = \\sqrt{3^2+4^2}=5$. $R+r=1+4=5$. Les cercles sont tangents extérieurement.\n\n⚠️ VIGILANCE : $O\\Omega = R+r$ ⇔ tangence extérieure.\n\n💡 ASTUCE : Calculer la distance entre les centres et la comparer aux rayons." });
      else if(i===21) questionsData.push({ id: 21, statement: "Soient $A$ et $B$ deux points distincts du plan et $\\Omega$ l'ensemble des isométries du plan qui laissent globalement invariant le segment $[AB]$.", choices: ["$\\text{Card}(\\Omega) = 2$", "$\\text{Card}(\\Omega) = 3$", "$\\text{Card}(\\Omega) = 4$", "$\\text{Card}(\\Omega) = 8$"], correct: 2, theme: "Isométries", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\nLes isométries laissant $[AB]$ globalement invariant sont : l'identité, la symétrie d'axe $(AB)$, la symétrie d'axe la médiatrice de $[AB]$, et la symétrie centrale du milieu de $[AB]$. Soit 4 isométries.\n\n⚠️ VIGILANCE : « Globalement invariant » signifie que l'image du segment est le segment lui-même.\n\n💡 ASTUCE : Un segment a 4 symétries : identité, deux réflexions, une rotation de $\\pi$." });
      else if(i===22) questionsData.push({ id: 22, statement: "Dans le plan rapporté à repère orthonormé $(O, \\vec{i}, \\vec{j})$, on donne la courbe $C$ d'équation $y = x - \\sqrt{x^2 - x + 1}$. L'image de $C$ par $S_O$ a pour équation :", choices: ["$y = -x - \\sqrt{x^2 + x + 1}$", "$y = x - \\sqrt{x^2 + x + 1}$", "$y = x + \\sqrt{x^2 - x + 1}$", "$y = x + \\sqrt{x^2 + x + 1}$"], correct: 3, theme: "Géométrie — Symétrie centrale", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$S_O$ transforme $(x,y)$ en $(-x,-y)$. L'image de $C$ : $-y = -x - \\sqrt{x^2 + x + 1}$, soit $y = x + \\sqrt{x^2 + x + 1}$.\n\n⚠️ VIGILANCE : Bien remplacer $x$ par $-x$ et $y$ par $-y$ dans l'équation.\n\n💡 ASTUCE : $S_O : (x,y) \\mapsto (-x,-y)$." });
      else if(i===23) questionsData.push({ id: 23, statement: "Soit $\\alpha$ un réel et $A$ et $B$ deux points distincts du plan $P$. L'ensemble des points $M$ du plan vérifiant $\\alpha\\overrightarrow{MA} + (1-\\alpha)\\overrightarrow{MB} = \\vec{0}$ lorsque $\\alpha$ varie dans $\\mathbb{R}$ est :", choices: ["$P$", "$(AB)$", "$[AB]$", "$(AB) \\setminus \\{A, B\\}$"], correct: 1, theme: "Géométrie — Barycentres", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nL'équation définit $M$ comme le barycentre de $(A,\\alpha)$ et $(B,1-\\alpha)$. Pour chaque $\\alpha$, $M$ est sur la droite $(AB)$. L'ensemble est la droite $(AB)$ tout entière.\n\n⚠️ VIGILANCE : Pour $\\alpha=0$, $M=B$ ; pour $\\alpha=1$, $M=A$.\n\n💡 ASTUCE : L'ensemble des barycentres de deux points est la droite passant par ces points." });
      else if(i===24) questionsData.push({ id: 24, statement: "Dans l'espace rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j}, \\vec{k})$, on considère la droite $\\mathscr{D}$ et le plan $\\mathscr{P}$ d'équations respectives : $$\\mathscr{D} : \\begin{cases} x = -3\\alpha \\\\ y = 2 - \\alpha \\\\ z = -1 + 2\\alpha \\end{cases},\\ \\alpha \\in \\mathbb{R} \\quad \\text{et} \\quad \\mathscr{P} : 2y + z = 0$$", choices: ["$\\mathscr{D}$ est contenue dans $\\mathscr{P}$", "$\\mathscr{D}$ et $\\mathscr{P}$ sont sécants", "$\\mathscr{D}$ et $\\mathscr{P}$ sont disjoints", "$\\mathscr{D}$ est orthogonale à $\\mathscr{P}$"], correct: 2, theme: "Géométrie dans l'espace", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\nSubstituons dans $\\mathscr{P}$ : $2(2-\\alpha) + (-1+2\\alpha) = 4-2\\alpha-1+2\\alpha = 3 \\neq 0$. $\\mathscr{D} \\cap \\mathscr{P} = \\emptyset$, ils sont disjoints (parallèles).\n\n⚠️ VIGILANCE : $2y+z=3$ constant, donc la droite est parallèle au plan.\n\n💡 ASTUCE : Substituer les équations paramétriques dans l'équation du plan." });
      else if(i===25) questionsData.push({ id: 25, statement: "L'espace est rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j}, \\vec{k})$. La distance du point $A(1, -1, 2)$ au plan $2x - 2y + z + 3 = 0$ est :", choices: ["$3$", "$\\sqrt{3}$", "$\\dfrac{1}{3}$", "$\\dfrac{\\sqrt{3}}{3}$"], correct: 0, theme: "Géométrie dans l'espace — Distance", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$d = \\frac{|2(1) - 2(-1) + 2 + 3|}{\\sqrt{2^2+(-2)^2+1^2}} = \\frac{|2+2+2+3|}{\\sqrt{4+4+1}} = \\frac{9}{\\sqrt{9}} = \\frac{9}{3}=3$.\n\n⚠️ VIGILANCE : $\\sqrt{9}=3$.\n\n💡 ASTUCE : $d(A,P) = \\frac{|ax_A+by_A+cz_A+d|}{\\sqrt{a^2+b^2+c^2}}$." });
      else if(i===26) questionsData.push({ id: 26, statement: "Dans l'espace rapporté à un repère orthonormé $(O, \\vec{i}, \\vec{j}, \\vec{k})$, on donne la droite $\\mathscr{D}$ passant par le point $B(2, -2, 3)$ et de vecteur directeur $\\vec{u} = \\begin{pmatrix}2\\\\-2\\\\1\\end{pmatrix}$. La distance du point $A(1, -1, 2)$ à la droite $\\mathscr{D}$ est :", choices: ["$\\sqrt{2}$", "$\\dfrac{1}{\\sqrt{2}}$", "$\\dfrac{\\sqrt{2}}{3}$", "$\\dfrac{1}{3}$"], correct: 0, theme: "Géométrie dans l'espace — Distance", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$\\overrightarrow{AB} = (1,-1,1)$. $\\overrightarrow{AB} \\wedge \\vec{u} = \\begin{vmatrix} \\vec{i} & \\vec{j} & \\vec{k} \\\\ 1 & -1 & 1 \\\\ 2 & -2 & 1 \\end{vmatrix} = \\vec{i}(-1\\cdot1 - 1\\cdot(-2)) - \\vec{j}(1\\cdot1 - 1\\cdot2) + \\vec{k}(1\\cdot(-2) - (-1)\\cdot2) = \\vec{i}(-1+2) - \\vec{j}(1-2) + \\vec{k}(-2+2) = (1,1,0)$. $\\|\\vec{AB} \\wedge \\vec{u}\\| = \\sqrt{2}$. $\\|\\vec{u}\\| = \\sqrt{4+4+1}=3$. $d = \\frac{\\sqrt{2}}{3}$? Non, $\\sqrt{2}/3$. Vérifions : $\\overrightarrow{AB} = (1-2, -1+2, 2-3) = (-1,1,-1)$. $\\overrightarrow{AB} \\wedge \\vec{u} = \\begin{vmatrix} \\vec{i} & \\vec{j} & \\vec{k} \\\\ -1 & 1 & -1 \\\\ 2 & -2 & 1 \\end{vmatrix} = \\vec{i}(1\\cdot1 - (-1)(-2)) - \\vec{j}((-1)\\cdot1 - (-1)\\cdot2) + \\vec{k}((-1)(-2) - 1\\cdot2) = \\vec{i}(1-2) - \\vec{j}(-1+2) + \\vec{k}(2-2) = (-1,-1,0)$. $\\|\\vec{AB} \\wedge \\vec{u}\\| = \\sqrt{2}$. $\\|\\vec{u}\\| = 3$. $d = \\frac{\\sqrt{2}}{3}$.\n\n⚠️ VIGILANCE : Le produit vectoriel se calcule avec le déterminant formel.\n\n💡 ASTUCE : $d(A,D) = \\frac{\\|\\vec{AB} \\wedge \\vec{u}\\|}{\\|\\vec{u}\\|}$." });
      else if(i===27) questionsData.push({ id: 27, statement: "L'énoncé du théorème de Gauss est :", choices: ["$\\forall a, b, c$ dans $\\mathbb{Z}^*$. Si $a \\mid bc$ et $a \\wedge b = 1$ alors $a \\mid c$", "$\\forall a, b, c$ dans $\\mathbb{Z}^*$. Si $a \\mid bc$ et $c \\wedge b = 1$ alors $a \\mid c$", "$\\forall a, b, c$ dans $\\mathbb{Z}^*$. Si $a \\mid bc$ alors $a \\mid b$ ou $a \\mid c$", "$\\forall a, b, c$ dans $\\mathbb{Z}^*$. Si $a \\mid b$ et $a \\mid c$ alors $a \\mid c$"], correct: 0, theme: "Arithmétique — Lemme de Gauss", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\nLe lemme de Gauss s'énonce : Si $a$ divise $bc$ et si $a$ est premier avec $b$, alors $a$ divise $c$.\n\n⚠️ VIGILANCE : Ne pas confondre avec le théorème de Bezout.\n\n💡 ASTUCE : « $a \\mid bc$ et $a \\wedge b = 1$ ⇒ $a \\mid c$ »." });
      else if(i===28) questionsData.push({ id: 28, statement: "L'ensemble de solutions dans $\\mathbb{Z}^2$ de l'équation $12x - 5y = 3$ est :", choices: ["$\\emptyset$", "$\\{(4+10k,\\ 9+24k),\\ k \\in \\mathbb{Z}\\}$", "$\\{(3+5k,\\ 7+12k),\\ k \\in \\mathbb{Z}\\}$", "$\\{(9+5k,\\ 21+12k),\\ k \\in \\mathbb{Z}\\}$"], correct: 3, theme: "Arithmétique — Équation diophantienne", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$12 \\wedge 5 = 1$ divise $3$, donc solutions. Solution particulière : $12 \\times 4 - 5 \\times 9 = 48-45=3$, $(x_0,y_0)=(4,9)$. Solution générale : $x=4+5k$, $y=9+12k$. Réponse D : $x=9+5k$, $y=21+12k$ correspond à $k\\to k+1$.\n\n⚠️ VIGILANCE : Plusieurs paramétrisations possibles.\n\n💡 ASTUCE : Vérifier la solution particulière : $12 \\times 9 - 5 \\times 21 = 108-105=3$." });
      else if(i===29) questionsData.push({ id: 29, statement: "L'ensemble des solutions dans $\\mathbb{Z}$ de l'équation $x^3 \\equiv 2\\ [7]$ est :", choices: ["infini", "vide", "$\\{7k+1,\\ k \\in \\mathbb{Z}\\}$", "$\\{7k-1,\\ k \\in \\mathbb{Z}\\}$"], correct: 1, theme: "Arithmétique — Congruences", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nCalculons les cubes modulo 7 : $0^3=0$, $1^3=1$, $2^3=8\\equiv1$, $3^3=27\\equiv6$, $4^3=64\\equiv1$, $5^3=125\\equiv6$, $6^3=216\\equiv6$. Aucun cube n'est congru à $2$ modulo $7$. L'ensemble est vide.\n\n⚠️ VIGILANCE : Tous les cubes modulo 7 sont $0,1$ ou $6$.\n\n💡 ASTUCE : Tester systématiquement les résidus modulo 7." });
      else if(i===30) questionsData.push({ id: 30, statement: "Soit un entier $n > 2$. Le reste de la division euclidienne de $n^2 + 3n + 3$ par $n+1$ est :", choices: ["$n-1$", "$n$", "$0$", "$1$"], correct: 3, theme: "Arithmétique — Division euclidienne", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$n^2+3n+3 = (n+1)(n+2) + 1$. Le reste est $1$.\n\n⚠️ VIGILANCE : $n^2+3n+2 = (n+1)(n+2)$.\n\n💡 ASTUCE : Factoriser $n^2+3n+2$." });
      else if(i===31) questionsData.push({ id: 31, statement: "Le reste de la division euclidienne d'un entier naturel $n$ par 12 est 8. Le reste de sa division euclidienne par 6 est :", choices: ["$1$", "$2$", "$3$", "$4$"], correct: 1, theme: "Arithmétique — Divisibilité", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$n = 12q + 8 = 6(2q) + 6 + 2 = 6(2q+1) + 2$. Le reste est $2$.\n\n⚠️ VIGILANCE : $8 = 6 + 2$.\n\n💡 ASTUCE : $12q+8 = 6(2q)+6+2$." });
      else if(i===32) questionsData.push({ id: 32, statement: "Un nombre en base 9 s'écrit 100101. Son écriture décimale est :", choices: ["$59121$", "$59129$", "$59131$", "$59139$"], correct: 2, theme: "Arithmétique — Changement de base", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$100101_9 = 1\\cdot9^5 + 0\\cdot9^4 + 0\\cdot9^3 + 1\\cdot9^2 + 0\\cdot9^1 + 1\\cdot9^0 = 59049 + 81 + 1 = 59131$.\n\n⚠️ VIGILANCE : $9^5=59049$, $9^2=81$.\n\n💡 ASTUCE : Les puissances de 9 : $1,9,81,729,6561,59049,...$." });
      else if(i===33) questionsData.push({ id: 33, statement: "On considère dans $\\mathbb{Z}^2$ l'équation $(E) : ax + by = c$ où $a$, $b$ et $c$ sont trois entiers non nuls.", choices: ["$(E)$ possède des solutions si et seulement si $(a \\wedge b) \\mid c$", "$(E)$ possède des solutions pour tous entiers $a$, $b$ et $c$ non nuls", "$(E)$ possède des solutions si et seulement si $c \\mid (a \\wedge b)$", "Si $(E)$ possède des solutions alors $a \\mid c$"], correct: 0, theme: "Arithmétique — Bezout", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\nC'est le théorème de Bezout : $ax+by=c$ admet des solutions entières ssi $\\text{pgcd}(a,b)$ divise $c$.\n\n⚠️ VIGILANCE : La condition est $(a \\wedge b) \\mid c$, pas l'inverse.\n\n💡 ASTUCE : $15x+6y=4$ n'a pas de solution car $3 \\nmid 4$." });
      else if(i===34) questionsData.push({ id: 34, statement: "Le système $\\begin{cases} 3x \\equiv 4\\ [7] \\\\ 2x \\equiv 4\\ [6] \\end{cases}$ est équivalent à :", choices: ["$\\begin{cases} 3x \\equiv 4\\ [7] \\\\ x \\equiv 2\\ [6] \\end{cases}$", "$\\begin{cases} x \\equiv 6\\ [7] \\\\ x \\equiv 2\\ [6] \\end{cases}$", "$\\begin{cases} x \\equiv 6\\ [7] \\\\ x \\equiv 2\\ [3] \\end{cases}$", "$\\begin{cases} x \\equiv 4\\ [7] \\\\ x \\equiv 2\\ [3] \\end{cases}$"], correct: 2, theme: "Arithmétique — Système de congruences", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$3x \\equiv 4$ [7] : $3^{-1}=5$, $x \\equiv 5\\times4=20\\equiv6$ [7]. $2x \\equiv 4$ [6] : simplifions par pgcd$(2,6)=2$ : $x \\equiv 2$ [3]. Donc $x \\equiv 6$ [7] et $x \\equiv 2$ [3].\n\n⚠️ VIGILANCE : $2x \\equiv 4$ [6] ⇔ $x \\equiv 2$ [3], pas [6].\n\n💡 ASTUCE : Quand le coefficient n'est pas inversible modulo $n$, simplifier par le pgcd." });
      else if(i===35) questionsData.push({ id: 35, statement: "L'ensemble de solutions dans $\\mathbb{Z}$ du système $\\begin{cases} x \\equiv 2\\ [5] \\\\ x \\equiv 3\\ [11] \\end{cases}$ est :", choices: ["$\\{5 + 55k,\\ k \\in \\mathbb{Z}\\}$", "$\\{6 + 55k,\\ k \\in \\mathbb{Z}\\}$", "$\\{47 + 55k,\\ k \\in \\mathbb{Z}\\}$", "$\\{49 + 55k,\\ k \\in \\mathbb{Z}\\}$"], correct: 2, theme: "Arithmétique — Théorème chinois", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$5$ et $11$ premiers entre eux. $x = 2+5k$. Modulo 11 : $2+5k \\equiv 3$ [11] ⇒ $5k \\equiv 1$ [11]. $5^{-1}=9$, $k \\equiv 9$ [11]. $k=9+11t$. $x=2+5(9+11t)=47+55t$.\n\n⚠️ VIGILANCE : Trouver l'inverse de 5 modulo 11 : $5\\times9=45\\equiv1$ [11].\n\n💡 ASTUCE : Théorème des restes chinois." });
      else if(i===36) questionsData.push({ id: 36, statement: "La négation de la proposition « il existe $x \\in \\mathbb{R}$ tel que pour tout réel $y$, $y^2 < x$ » est :", choices: ["Pour tout réel $x$, il existe un réel $y$ vérifiant $y^2 < x$", "Pour tout réel $x$, il existe un réel $y$ vérifiant $y^2 \\ge x$", "Pour tout réel $x$ et pour tout réel $y$, $y^2 \\ge x$", "Il existe un réel $x$, tel que pour tout réel $y$, $y^2 \\ge x$"], correct: 1, theme: "Logique mathématique", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$\\neg(\\exists x, \\forall y, y^2<x) = \\forall x, \\exists y, y^2 \\ge x$.\n\n⚠️ VIGILANCE : La négation de $<$ est $\\ge$.\n\n💡 ASTUCE : $\\neg(\\exists x, \\forall y, P) \\equiv \\forall x, \\exists y, \\neg P$." });
      else if(i===37) questionsData.push({ id: 37, statement: "Soit une fonction $f : \\mathbb{R} \\to \\mathbb{R}$. La négation de « $f$ est constante sur $\\mathbb{R}$ » est :", choices: ["Pour tous réels $x$ et $y$, $f(x) < f(y)$", "Pour tous réels $x$ et $y$, $f(x) \\neq f(y)$", "Il existe deux réels distincts $x$ et $y$ tels que $f(x) \\neq f(y)$", "Pour tous réels distincts $x$ et $y$, $f(x) \\neq f(y)$"], correct: 2, theme: "Logique mathématique", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n« $f$ est constante » = $\\forall x, \\forall y, f(x)=f(y)$. Sa négation : $\\exists x, \\exists y, f(x) \\neq f(y)$.\n\n⚠️ VIGILANCE : La négation de $\\forall$ est $\\exists$.\n\n💡 ASTUCE : Il suffit de trouver deux points où la fonction diffère." });
      else if(i===38) questionsData.push({ id: 38, statement: "L'équation $(E) : x^3 - 2x^2 + 4x - 1 = 0$ :", choices: ["admet une racine dans $\\mathbb{Z}$", "n'admet pas de racines réelles", "admet une unique racine réelle", "admet deux racines réelles opposées"], correct: 2, theme: "Analyse — Théorème des valeurs intermédiaires", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$f(x)=x^3-2x^2+4x-1$. $f'(x)=3x^2-4x+4$, $\\Delta=16-48=-32<0$, $f'>0$. $f$ strictement croissante sur $\\mathbb{R}$. $\\lim_{-\\infty}f=-\\infty$, $\\lim_{+\\infty}f=+\\infty$, donc une unique racine réelle.\n\n⚠️ VIGILANCE : $f(1)=2$, $f(0)=-1$, donc racine entre $0$ et $1$.\n\n💡 ASTUCE : Une fonction strictement monotone et continue a au plus une racine." });
      else if(i===39) questionsData.push({ id: 39, statement: "L'équation $(E) : x^{16} + 2x^{10} + 3x^2 + 3 = 0$ :", choices: ["n'admet aucune racine réelle", "admet au moins une racine réelle", "admet des racines réelles opposées", "admet exactement 16 racines réelles"], correct: 0, theme: "Analyse — Équations polynomiales", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$x^{16} \\ge 0$, $x^{10} \\ge 0$, $x^2 \\ge 0$, donc $x^{16}+2x^{10}+3x^2+3 \\ge 3 > 0$ pour tout $x$. Pas de racine réelle.\n\n⚠️ VIGILANCE : Les puissances paires sont toujours $\\ge 0$.\n\n💡 ASTUCE : Somme de termes positifs ou nuls + constante positive ne peut pas s'annuler." });
      else if(i===40) questionsData.push({ id: 40, statement: "On considère dans $\\mathbb{C}$ l'équation $(E) : z^4 + 2z^2 + z + 3 = 0$. Si $z_0$ est une solution de $(E)$ alors :", choices: ["$\\dfrac{1}{z_0}$ est une solution de $(E)$", "$\\bar{z_0}$ est une solution de $(E)$", "$i z_0$ est une solution de $(E)$", "$i\\bar{z_0}$ est une solution de $(E)$"], correct: 1, theme: "Nombres complexes — Équations polynomiales", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nLes coefficients sont réels, donc $P(\\bar{z}) = \\overline{P(z)} = 0$. $\\bar{z_0}$ est aussi solution.\n\n⚠️ VIGILANCE : Pour un polynôme à coefficients réels, les racines non réelles sont conjuguées.\n\n💡 ASTUCE : $P(\\bar{z}) = \\overline{P(z)}$." });
      else if(i===41) questionsData.push({ id: 41, statement: "Soit $P(z) = \\displaystyle\\sum_{k=0}^{10} z^k$ avec $z \\in \\mathbb{C}$.", choices: ["$P(z) \\neq 0,\\ \\forall z \\in \\mathbb{C}$", "$P(z) = 0$ admet exactement 11 solutions dans $\\mathbb{C}$", "Pour tout $y \\in \\mathbb{R}$ on a $P(iy) \\neq 0$", "Il existe au moins un réel $x$ tel que $P(x) = 0$"], correct: 2, theme: "Nombres complexes — Somme géométrique", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$P(z) = \\frac{z^{11}-1}{z-1}$. Les racines sont les racines $11$-ièmes de l'unité sauf $1$. Elles sont $e^{2ik\\pi/11}$, $k=1,...,10$. Aucune n'est imaginaire pure car $\\cos(2k\\pi/11)\\neq 0$. Donc $P(iy)\\neq0$.\n\n⚠️ VIGILANCE : $P(z)=0$ a 10 solutions, pas 11.\n\n💡 ASTUCE : $P(z)=0$ ⇔ $z^{11}=1$ et $z\\neq1$." });
      else if(i===42) questionsData.push({ id: 42, statement: "On considère les matrices $A = \\begin{pmatrix}1&1&1\\\\2&1&3\\\\1&-1&2\\end{pmatrix}$, $B = \\begin{pmatrix}0&2&1\\\\1&3&2\\\\-1&1&1\\end{pmatrix}$ et $C = \\begin{pmatrix}5&-3&2\\\\-1&1&-1\\\\-3&2&-1\\end{pmatrix}$.", choices: ["$A$ n'est pas inversible", "$C$ est la matrice inverse de $B$", "$B$ est la matrice inverse de $A$", "$C$ est la matrice inverse de $A$"], correct: 3, theme: "Algèbre linéaire — Matrices", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nVérifions $A \\times C = I_3$. $C$ est l'inverse de $A$.\n\n⚠️ VIGILANCE : Pour vérifier l'inverse, multiplier les deux matrices.\n\n💡 ASTUCE : $A \\times C = I_3$ se vérifie rapidement." });
      else if(i===43) questionsData.push({ id: 43, statement: "Soit $(U_n)$ une suite définie sur $\\mathbb{N}$. $(U_n)$ est une suite arithmétique si et seulement si :", choices: ["$\\forall n \\in \\mathbb{N},\\ \\exists r \\in \\mathbb{R}\\ /\\ U_{n+1} - U_n = r$", "$\\forall n \\in \\mathbb{N},\\ U_n = \\dfrac{U_{n+1} + U_{n+2}}{2}$", "$\\forall n \\in \\mathbb{N},\\ U_{n+1} = \\dfrac{U_{n+2} - U_n}{2}$", "$\\forall n \\in \\mathbb{N},\\ 2U_{n+1} = U_n + U_{n+2}$"], correct: 3, theme: "Suites — Suite arithmétique", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nUne suite est arithmétique ssi $2U_{n+1}=U_n+U_{n+2}$ (chaque terme est la moyenne arithmétique de ses voisins).\n\n⚠️ VIGILANCE : La réponse A est mal quantifiée.\n\n💡 ASTUCE : Caractérisation des suites arithmétiques." });
      else if(i===44) questionsData.push({ id: 44, statement: "Soit $f$ une fonction définie sur un intervalle $I$. L'énoncé du théorème des valeurs intermédiaires est :", choices: ["Si $f$ est continue sur $I$ alors $f(I)$ est un intervalle", "Si $f$ est monotone et continue sur $I$ alors pour tout $\\beta \\in f(I)$ il existe un réel unique $\\alpha \\in I$ tel que $f(\\alpha) = \\beta$", "Si $f$ est monotone sur $I$ alors pour tout $\\beta \\in f(I)$ il existe un réel unique $\\alpha \\in I$ tel que $f(\\alpha) = \\beta$", "Si $f$ est continue sur $I$ alors $I$ et $f(I)$ sont des intervalles de même nature"], correct: 0, theme: "Analyse — Théorème des valeurs intermédiaires", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\nLe TVI affirme que l'image d'un intervalle par une fonction continue est un intervalle.\n\n⚠️ VIGILANCE : Ne pas confondre TVI et son corollaire pour les fonctions strictement monotones.\n\n💡 ASTUCE : Continuité ⇒ image d'un intervalle est un intervalle." });
      else if(i===45) questionsData.push({ id: 45, statement: "L'ensemble de définition de la fonction $f$ définie par $f(x) = \\sqrt{(x-1)^4(x-4)^3}$ est :", choices: ["$[4; +\\infty[$", "$]-\\infty; 4]$", "$[0; 4]$", "$[4; +\\infty[ \\cup \\{1\\}$"], correct: 3, theme: "Analyse — Domaine de définition", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$(x-1)^4 \\ge 0$ toujours. $(x-4)^3 \\ge 0$ ssi $x \\ge 4$. Le produit est $\\ge 0$ pour $x \\ge 4$. De plus, $x=1$ donne $0$, OK. $D_f = [4,+\\infty[ \\cup \\{1\\}$.\n\n⚠️ VIGILANCE : Une puissance paire est toujours positive.\n\n💡 ASTUCE : $(x-1)^4 \\ge 0$, $(x-4)^3$ change de signe en $4$." });
      else if(i===46) questionsData.push({ id: 46, statement: "Soient $f$ et $g$ deux fonctions définies par : $$f(x) = \\begin{cases}3x^2 & \\text{si } x < 1,\\\\ f(1) = 0,\\\\ 3x^2 + 1 & \\text{si } x > 1.\\end{cases} \\quad \\text{et} \\quad g(x) = \\begin{cases}-x+1 & \\text{si } x < 1,\\\\ g(1) = 3,\\\\ -x & \\text{si } x > 1.\\end{cases}$$", choices: ["$(f+g)$ est discontinue en 1", "$(f+g)$ est continue en 1", "$(2f+g)$ est continue en 1", "$(3f-g)$ est continue en 1"], correct: 1, theme: "Analyse — Continuité", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$f(1^-)=3$, $f(1)=0$, $f(1^+)=4$. $g(1^-)=0$, $g(1)=3$, $g(1^+)=-1$. $(f+g)(1^-)=3$, $(f+g)(1)=3$, $(f+g)(1^+)=3$. Continue en $1$.\n\n⚠️ VIGILANCE : La somme de deux fonctions discontinues peut être continue.\n\n💡 ASTUCE : Vérifier les limites à gauche, la valeur au point, et la limite à droite." });
      else if(i===47) questionsData.push({ id: 47, statement: "Soit $f$ une fonction continue sur $[a,b]$ et dérivable sur $]a,b[$ telle que $f(a) = f(b)$. Alors :", choices: ["$f$ est constante sur $[a,b]$", "Il existe $c \\in ]a,b[$ tel que $f'(c) = 0$", "$f$ admet un extremum en $a$ ou $b$", "$f'$ est nulle sur $]a,b[$"], correct: 1, theme: "Analyse — Théorème de Rolle", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nC'est l'énoncé du théorème de Rolle : si $f$ continue sur $[a,b]$, dérivable sur $]a,b[$ et $f(a)=f(b)$, alors il existe $c$ tel que $f'(c)=0$.\n\n⚠️ VIGILANCE : $f$ n'est pas nécessairement constante (ex: $\\sin$ sur $[0,2\\pi]$).\n\n💡 ASTUCE : Théorème de Rolle = cas particulier des accroissements finis." });
      else if(i===48) questionsData.push({ id: 48, statement: "L'intégrale $\\displaystyle\\int_0^1 x e^{x^2}\\,dx$ est égale à :", choices: ["$e$", "$e-1$", "$\\dfrac{e-1}{2}$", "$\\dfrac{e}{2}$"], correct: 2, theme: "Intégration — Changement de variable", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$\\int_0^1 x e^{x^2} dx = \\frac{1}{2}[e^{x^2}]_0^1 = \\frac{1}{2}(e-1)$.\n\n⚠️ VIGILANCE : Reconnaître $u' e^u$ avec $u=x^2$, $u'=2x$.\n\n💡 ASTUCE : $\\int u'(x)e^{u(x)}dx = e^{u(x)}+C$." });
      else if(i===49) questionsData.push({ id: 49, statement: "Soit la suite $(U_n)$ définie par $U_0 = 1$ et $U_{n+1} = \\sqrt{2+U_n}$. La limite de $(U_n)$ est :", choices: ["$1$", "$2$", "$\\sqrt{2}$", "$+\\infty$"], correct: 1, theme: "Suites — Convergence", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nPoint fixe : $\\ell = \\sqrt{2+\\ell}$ ⇒ $\\ell^2 = 2+\\ell$ ⇒ $\\ell^2-\\ell-2=0$ ⇒ $(\\ell-2)(\\ell+1)=0$, $\\ell=2$ (car $\\ell\\ge0$). La suite croît et converge vers $2$.\n\n⚠️ VIGILANCE : Écarter $\\ell=-1$.\n\n💡 ASTUCE : $U_0=1$, $U_1=\\sqrt{3}\\approx1.73$, $U_2\\approx1.93$, ..." });
      else if(i===50) questionsData.push({ id: 50, statement: "La série $\\displaystyle\\sum_{n \\ge 1} \\frac{1}{n(n+1)}$ :", choices: ["diverge", "converge et sa somme vaut $1$", "converge et sa somme vaut $2$", "converge et sa somme vaut $0$"], correct: 1, theme: "Séries — Série télescopique", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$\\frac{1}{n(n+1)} = \\frac{1}{n} - \\frac{1}{n+1}$. Série télescopique : $S_N = 1 - \\frac{1}{N+1} \\to 1$.\n\n⚠️ VIGILANCE : Décomposition en éléments simples.\n\n💡 ASTUCE : $\\frac{1}{n(n+1)} = \\frac{1}{n} - \\frac{1}{n+1}$." });
      else if(i===51) questionsData.push({ id: 51, statement: "Le rayon de convergence de la série entière $\\displaystyle\\sum_{n \\ge 0} \\frac{x^n}{2^n}$ est :", choices: ["$0$", "$1$", "$2$", "$+\\infty$"], correct: 2, theme: "Séries entières", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$\\sum (x/2)^n$ converge ssi $|x/2|<1$, soit $|x|<2$. Rayon $R=2$.\n\n⚠️ VIGILANCE : Rayon $=2$, pas $1/2$.\n\n💡 ASTUCE : Série géométrique de raison $x/2$." });
      else if(i===52) questionsData.push({ id: 52, statement: "Soit la fonction $f$ définie par $f(x) = \\dfrac{\\ln\\!\\left(x + \\sqrt{x^2+x+1}\\right)}{x}$. La limite de $f$ en 0 est égale à :", choices: ["$-\\infty$", "$+\\infty$", "$\\dfrac{1}{2}$", "$\\dfrac{3}{2}$"], correct: 3, theme: "Analyse — Limites, DL", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$\\sqrt{x^2+x+1} = 1 + \\frac{x}{2} + \\frac{3x^2}{8} + o(x^2)$. $x+\\sqrt{...} = 1 + \\frac{3x}{2} + o(x)$. $\\ln(1+u) = u - u^2/2 + ...$, $u=\\frac{3x}{2}+o(x)$. $\\ln(...) = \\frac{3x}{2} + o(x)$. $f(x) = \\frac{3}{2} + o(1) \\to \\frac{3}{2}$.\n\n⚠️ VIGILANCE : DL de $\\sqrt{1+u}$ : $1+u/2-u^2/8+...$\n\n💡 ASTUCE : $f(0)$ est une forme $0/0$, utiliser les DL." });
      else if(i===53) questionsData.push({ id: 53, statement: "Soit la fonction $f$ définie par $f(x) = x\\ln\\!\\left(1 + \\dfrac{2}{x}\\right)$. La limite de $f$ en $+\\infty$ est égale à :", choices: ["$0$", "$1$", "$2$", "$+\\infty$"], correct: 2, theme: "Analyse — Limites, croissances comparées", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$f(x) = x\\ln(1+2/x)$. $\\ln(1+u) \\sim u$ pour $u\\to0$. $f(x) \\sim x \\cdot (2/x) = 2 \\to 2$.\n\n⚠️ VIGILANCE : $\\ln(1+2/x) \\sim 2/x$.\n\n💡 ASTUCE : Utiliser l'équivalent $\\ln(1+u)\\sim u$." });
      else if(i===54) questionsData.push({ id: 54, statement: "Pour tout $x \\in [0, +\\infty[$, on a :", choices: ["$\\sin(x) \\ge x$", "$x - \\dfrac{x^3}{6} \\le \\sin(x) \\le x$", "$x \\le \\sin(x) \\le x + \\dfrac{x^3}{6}$", "$x - \\dfrac{x^3}{6} < \\sin(x) < x$"], correct: 1, theme: "Analyse — Inégalités classiques", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\nInégalité classique : $x - \\frac{x^3}{6} \\le \\sin x \\le x$ pour $x \\ge 0$.\n\n⚠️ VIGILANCE : L'inégalité de droite est $\\sin x \\le x$.\n\n💡 ASTUCE : Ces inégalités proviennent du développement en série de Taylor." });
      else if(i===55) questionsData.push({ id: 55, statement: "Pour tout $x \\in ]-1, +\\infty[$, on a :", choices: ["$\\ln(1+x) > -x$", "$\\ln(1+x) < x$", "$\\ln(1+x) \\le x$", "$\\ln(1+x) \\le 1 - x$"], correct: 2, theme: "Analyse — Inégalités classiques", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$\\ln(1+x) \\le x$ pour tout $x > -1$, avec égalité en $x=0$.\n\n⚠️ VIGILANCE : L'inégalité est large ($\\le$).\n\n💡 ASTUCE : $f(x)=x-\\ln(1+x) \\ge 0$ sur $]-1,+\\infty[$." });
      else if(i===56) questionsData.push({ id: 56, statement: "Soit $(U_n)$ une suite définie par $\\begin{cases}U_0 \\text{ un réel donné}\\\\ \\forall n \\in \\mathbb{N},\\ U_{n+1} = e^{U_n} - 1\\end{cases}$", choices: ["Pour toute valeur de $U_0$, $(U_n)$ est divergente", "Pour toute valeur de $U_0$, $(U_n)$ est convergente", "Si $U_0 < 0$ alors $(U_n)$ est convergente", "Si $U_0 < 0$ alors $(U_n)$ est divergente"], correct: 2, theme: "Suites — Suite récurrente", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\n$f(x)=e^x-1$. $f(x)-x = e^x-1-x \\ge 0$, donc $U_{n+1} \\ge U_n$, suite croissante. Si $U_0<0$, $U_n$ croît et est majorée par $0$, donc converge vers $0$. Si $U_0>0$, $U_n \\to +\\infty$.\n\n⚠️ VIGILANCE : $f(x)-x \\ge 0$ car $e^x \\ge 1+x$.\n\n💡 ASTUCE : Étudier le point fixe $x=0$ et le signe de $f(x)-x$." });
      else if(i===57) questionsData.push({ id: 57, statement: "Pour tout $n \\in \\mathbb{N}$, on pose $I_n = \\displaystyle\\int_0^1 \\dfrac{e^{nx}}{1+e^x}\\,dx$. La suite $(I_n)$ est :", choices: ["croissante", "décroissante", "convergente", "majorée"], correct: 0, theme: "Intégration — Suite d'intégrales", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$I_{n+1}-I_n = \\int_0^1 \\frac{e^{nx}(e^x-1)}{1+e^x}dx \\ge 0$, donc croissante.\n\n⚠️ VIGILANCE : $I_n \\to +\\infty$, divergente.\n\n💡 ASTUCE : $I_n \\ge \\int_0^1 \\frac{e^{nx}}{e+1}dx = \\frac{1}{(e+1)n}(e^n-1) \\to +\\infty$." });
      else if(i===58) questionsData.push({ id: 58, statement: "On pose $S_n = \\displaystyle\\sum_{k=0}^{n} U_k$ où $(U_n)$ est une suite réelle. Si $S_n = n^3$ alors :", choices: ["pour tout $n \\in \\mathbb{N}$, $U_n = n^2$", "$(U_n)$ est une suite arithmétique", "$(U_n)$ est une suite géométrique", "pour tout $n \\in \\mathbb{N}^*$, $U_n = 3n^2 - 3n + 1$"], correct: 3, theme: "Suites — Relation somme-terme", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$U_n = S_n - S_{n-1} = n^3 - (n-1)^3 = 3n^2 - 3n + 1$ pour $n\\ge1$. $U_0 = S_0 = 0$.\n\n⚠️ VIGILANCE : $(n-1)^3 = n^3 - 3n^2 + 3n - 1$.\n\n💡 ASTUCE : $U_n = S_n - S_{n-1}$." });
      else if(i===59) questionsData.push({ id: 59, statement: "Pour tout $n \\in \\mathbb{N}^*$, on pose $H_n = \\displaystyle\\prod_{k=1}^{n} U_k$ où $(U_n)_{n \\in \\mathbb{N}^*}$ est une suite réelle. Si $H_n = \\dfrac{e^n}{n!}$ alors :", choices: ["pour tout $n \\in \\mathbb{N}^*$, $U_n = \\dfrac{e}{n}$", "pour tout $n \\in \\mathbb{N}^*$, $U_n = \\dfrac{e^{-1}}{n}$", "pour tout $n \\in \\mathbb{N}^*$, $U_n = \\dfrac{e}{(n-1)!}$", "$(U_n)_{n \\in \\mathbb{N}^*}$ est croissante"], correct: 0, theme: "Suites — Produit télescopique", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$U_n = H_n/H_{n-1} = \\frac{e^n/n!}{e^{n-1}/(n-1)!} = \\frac{e}{n}$.\n\n⚠️ VIGILANCE : $U_n = e/n$, suite décroissante.\n\n💡 ASTUCE : $H_n/H_{n-1} = U_n$ pour $n\\ge2$." });
      else if(i===60) questionsData.push({ id: 60, statement: "Soit l'équation différentielle $y' + 2y = \\cos(x) - 2\\sin(x)$. La solution générale de cette équation est :", choices: ["$y(x) = ke^{-2x} - \\dfrac{4}{5}\\cos(x);\\ k \\in \\mathbb{R}$", "$y(x) = ke^{-2x} - \\dfrac{3}{5}\\sin(x);\\ k \\in \\mathbb{R}$", "$y(x) = ke^{-2x} - \\dfrac{4}{5}\\cos(x) - \\dfrac{3}{5}\\sin(x);\\ k \\in \\mathbb{R}$", "$y(x) = ke^{-2x} + \\dfrac{4}{5}\\cos(x) - \\dfrac{3}{5}\\sin(x);\\ k \\in \\mathbb{R}$"], correct: 3, theme: "Équations différentielles", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nSolution homogène : $y_H = ke^{-2x}$. Solution particulière $y_P = A\\cos x + B\\sin x$. $y_P' = -A\\sin x + B\\cos x$. $y_P'+2y_P = (2A+B)\\cos x + (2B-A)\\sin x = \\cos x - 2\\sin x$. $2A+B=1$, $2B-A=-2$. On trouve $A=4/5$, $B=-3/5$. $y_P = \\frac{4}{5}\\cos x - \\frac{3}{5}\\sin x$.\n\n⚠️ VIGILANCE : Résoudre le système $2A+B=1$, $2B-A=-2$.\n\n💡 ASTUCE : Pour $y'+ay = \\alpha\\cos x + \\beta\\sin x$, chercher $y_P = A\\cos x + B\\sin x$." });
      else {
        questionsData.push({ id: i, statement: `Question ${i} : Contenu complet du Master CAPES 2017.`, choices: ["A: Option A", "B: Option B", "C: Option C", "D: Option D"], correct: 0, theme: "Mathématiques générales", niveau_scolaire: "Master", explication: `✅ Réponse : A\n\n🔍 Cette question fait partie du contenu premium du Master CAPES 2017 débloqué avec la clé SYN-MAESTRO-MATH.\n\n📖 Pack Spécial CAPES MATH 2026 inclus.\n\n💡 Contactez-nous pour l'accès complet.` });
      }
    }

    // ==================== FONCTIONS ====================
    document.addEventListener('DOMContentLoaded', function() {
      // 🔁 RESET FORCÉ POUR TESTS (à supprimer en production)
      localStorage.removeItem('synapris_client_name');
      localStorage.removeItem('synapris_unlocked');
      unlocked = false;
      
      const savedName = localStorage.getItem('synapris_client_name');
      const savedUnlock = localStorage.getItem('synapris_unlocked');
      if(savedUnlock === 'true') unlocked = true;
      if (savedName) { clientName = savedName;
        document.getElementById('client-name-footer').textContent = clientName;
        document.getElementById('mb-client-badge').style.display = 'inline-flex';
        document.getElementById('mb-client-badge').textContent = '🔑 ' + clientName;
        initDefaultMode(); } else { showNameModal(); }
    });

    function resetClientName() { localStorage.removeItem('synapris_client_name');
      clientName = '';
      document.getElementById('client-name-footer').textContent = '——';
      document.getElementById('mb-client-badge').style.display = 'none';
      showNameModal(); }

    function showNameModal() {
      const overlay = document.createElement('div');
      overlay.className = 'modal-overlay';
      overlay.id = 'name-modal';
      overlay.innerHTML = '<div class="modal-box"><h3>🌟 Bienvenue sur SYNAPRIS !</h3><p>Entrez votre prénom :</p><input type="text" class="key-input" id="name-input" placeholder="Votre prénom" autocomplete="off" /><div class="modal-error" id="name-error">❌ Prénom invalide.</div><div class="modal-actions"><button class="btn btn-gold" id="btn-name-ok">✅ Commencer</button></div></div>';
      document.body.appendChild(overlay);
      document.getElementById('btn-name-ok').addEventListener('click', () => {
        const name = document.getElementById('name-input').value.trim();
        if (name && name.length >= 2 && /^[A-Za-zÀ-ÿ\s\-]+$/.test(name)) { clientName = name;
          localStorage.setItem('synapris_client_name', clientName);
          document.getElementById('client-name-footer').textContent = clientName;
          document.getElementById('mb-client-badge').style.display = 'inline-flex';
          document.getElementById('mb-client-badge').textContent = '🔑 ' + clientName;
          overlay.remove();
          initDefaultMode(); } else { document.getElementById('name-error').style.display = 'block'; }
      });
    }

    function showRefModal() {
      const overlay = document.createElement('div');
      overlay.className = 'modal-overlay';
      overlay.innerHTML = '<div class="modal-box"><h3>📚 RÉFÉRENCES</h3><p><strong>Master CAPES 2017</strong><br>60 questions · 60 minutes<br>4 choix (A,B,C,D) · Une seule réponse correcte</p><div class="modal-actions"><button class="btn btn-primary" onclick="this.closest(\'.modal-overlay\').remove()">Fermer</button></div></div>';
      document.body.appendChild(overlay);
    }

    function initDefaultMode() { document.getElementById('mode-train').classList.add('selected');
      document.getElementById('btn-start').disabled = false;
      document.getElementById('btn-start').textContent = '📝 Mode Entraînement';
      document.getElementById('mb-mode-badge').style.display = 'inline-flex';
      document.getElementById('mb-mode-badge').textContent = '📝 Entraînement';
      document.getElementById('notice-train').classList.remove('hidden');
      document.getElementById('notice-exam').classList.add('hidden'); }

    function showPage(e) { document.querySelectorAll('#main-app .page').forEach(p => p.classList.remove('active'));
      document.getElementById(e).classList.add('active');
      document.getElementById('main-scroll').scrollTop = 0; }

    function selectMode(e) { mode = e;
      ['train', 'exam'].forEach(x => document.getElementById('mode-' + x)?.classList.remove('selected'));
      document.getElementById('mode-' + e).classList.add('selected');
      document.getElementById('btn-start').disabled = false;
      document.getElementById('btn-start').innerHTML = e === 'train' ? '📝 Mode Entraînement' : '⏱️ Mode Examen (60 min)';
      document.getElementById('mb-mode-badge').textContent = e === 'train' ? '📝 Entraînement' : '⏱️ Examen';
      document.getElementById('notice-train').classList.toggle('hidden', e !== 'train');
      document.getElementById('notice-exam').classList.toggle('hidden', e !== 'exam');
      document.body.classList.remove('train-mode', 'exam-mode');
      document.body.classList.add(e === 'train' ? 'train-mode' : 'exam-mode');
    }

    function startQuiz() {
      if(mode === 'exam') { showExamInstructionsModal(); return; }
      currentQ = 0;
      activeSet = questionsData.map((_, i) => i);
      if(!unlocked && activeSet.length > QUESTIONS_GRATUITES) {
        activeSet = activeSet.slice(0, QUESTIONS_GRATUITES);
      }
      userAnswers = new Array(activeSet.length).fill(null);
      validated = new Array(activeSet.length).fill(false);
      showPage('page-question');
      if (mode === 'exam') {
        document.body.classList.add('exam-mode');
        examSeconds = TOTAL_EXAM_SEC;
        perQSeconds = PER_Q_SEC;
        document.getElementById('timer-wrap').classList.remove('hidden');
        document.getElementById('perq-timer').classList.remove('hidden');
        startExamTimer();
        startPerQTimer();
        document.getElementById('btn-validate').classList.add('hidden');
        document.getElementById('grille-examen').classList.remove('hidden');
        buildGrilleExamen();
      } else {
        document.body.classList.remove('exam-mode');
        document.getElementById('timer-wrap').classList.add('hidden');
        document.getElementById('perq-timer').classList.add('hidden');
        if (examTimer) clearInterval(examTimer);
        if (perQTimer) clearInterval(perQTimer);
        document.getElementById('grille-examen').classList.add('hidden');
      }
      updateMiniBar();
      renderQuestion();
    }

    function buildGrilleExamen() {
      const container = document.getElementById('grille-table');
      const half = Math.ceil(activeSet.length / 2);
      let html = '<div class="grille-col">';
      for (let i = 0; i < half; i++) {
        const q = questionsData[activeSet[i]];
        const answered = userAnswers[i] !== null;
        html += `<div class="grille-row"><span class="grille-q-num${answered?' answered':''}" onclick="jumpToQuestion(${i})">Q${q.id}</span>`;
        ['A','B','C','D'].forEach((ltr, j) => {
          const checked = userAnswers[i] === j;
          html += `<span class="grille-case${checked?' checked':''}" onclick="selectChoiceFromGrille(${i},${j})">${ltr}</span>`;
        });
        html += '</div>';
      }
      html += '</div><div class="grille-col">';
      for (let i = half; i < activeSet.length; i++) {
        const q = questionsData[activeSet[i]];
        const answered = userAnswers[i] !== null;
        html += `<div class="grille-row"><span class="grille-q-num${answered?' answered':''}" onclick="jumpToQuestion(${i})">Q${q.id}</span>`;
        ['A','B','C','D'].forEach((ltr, j) => {
          const checked = userAnswers[i] === j;
          html += `<span class="grille-case${checked?' checked':''}" onclick="selectChoiceFromGrille(${i},${j})">${ltr}</span>`;
        });
        html += '</div>';
      }
      html += '</div>';
      container.innerHTML = html;
    }

    function selectChoiceFromGrille(qIndex, choiceIndex) { currentQ = qIndex; if (validated[currentQ]) return;
      userAnswers[currentQ] = choiceIndex;
      renderQuestion();
      buildGrilleExamen(); }

    function jumpToQuestion(qIndex) { 
      if(isQuestionLocked(qIndex) && !unlocked) {
        showUnlockModal();
        return;
      }
      currentQ = qIndex;
      if (mode === 'exam') { perQSeconds = PER_Q_SEC; updatePerQTimerDisplay(); }
      renderQuestion(); if (mode === 'exam') buildGrilleExamen(); 
    }

    function goHome() { if (examTimer) clearInterval(examTimer); if (perQTimer) clearInterval(perQTimer);
      document.body.classList.remove('exam-mode', 'train-mode');
      showPage('page-home'); }

    function updateMiniBar() { const e = currentQ + 1, t = activeSet.length;
      document.getElementById('mb-q-counter').textContent = `Q${e}/${t}`;
      document.getElementById('mb-progress-fill').style.width = (e / t * 100) + '%'; }

    function renderQuestion() {
      if(isQuestionLocked(currentQ) && !unlocked) {
        showUnlockModal();
        return;
      }
      const qIdx = activeSet[currentQ];
      const q = questionsData[qIdx];
      document.getElementById('q-statement').innerHTML = `❓ <strong>Q${q.id}.</strong> ${q.statement}`;
      const container = document.getElementById('q-choices');
      container.innerHTML = '';
      const correctIdx = q.correct;
      ['A','B','C','D'].forEach((ltr, i) => {
        if (i < q.choices.length) {
          const btn = document.createElement('button');
          btn.className = 'choice-btn';
          if (validated[currentQ]) {
            if (correctIdx === i) btn.classList.add('correct');
            else if (userAnswers[currentQ] === i) btn.classList.add('wrong');
          } else if (userAnswers[currentQ] === i) btn.classList.add('selected');
          btn.innerHTML = `<span class="choice-letter">${ltr}</span><span class="choice-text">${q.choices[i]}</span>`;
          if (!validated[currentQ]) {
            btn.onclick = () => {
              userAnswers[currentQ] = i;
              renderQuestion();
              if (mode === 'exam') buildGrilleExamen();
            };
          }
          container.appendChild(btn);
        }
      });
      const hasAnswer = userAnswers[currentQ] !== null;
      if (mode === 'train') document.getElementById('btn-validate').disabled = (!hasAnswer || validated[currentQ]);
      if (validated[currentQ] && mode === 'train') buildFeedback(q, userAnswers[currentQ]);
      else if (mode === 'train') { document.getElementById('feedback-placeholder').style.display = 'flex';
        document.getElementById('feedback-box').style.display = 'none'; }
      if (mode === 'exam') { 
        document.getElementById('feedback-placeholder').style.display = 'none'; 
        document.getElementById('feedback-box').style.display = 'none'; 
        document.getElementById('feedback-box').classList.remove('visible'); 
      }
      document.getElementById('btn-prev').disabled = (currentQ === 0);
      const nextBtn = document.getElementById('btn-next');
      if (currentQ === activeSet.length - 1) { nextBtn.innerHTML = '🏁 Terminer'; nextBtn.className = 'btn btn-gold'; }
      else { nextBtn.innerHTML = 'Suivant →'; nextBtn.className = 'btn btn-primary'; }
      if (typeof renderMathInElement !== 'undefined') {
        renderMathInElement(document.getElementById('q-statement'), { delimiters: [{left:"$$",right:"$$",display:true},{left:"$",right:"$",display:false}], throwOnError: false });
        renderMathInElement(container, { delimiters: [{left:"$$",right:"$$",display:true},{left:"$",right:"$",display:false}], throwOnError: false });
      }
      if (mode === 'exam') { perQSeconds = PER_Q_SEC; updatePerQTimerDisplay(); buildGrilleExamen(); }
    }

    function validateAnswer() { if (userAnswers[currentQ] === null) return;
      validated[currentQ] = true;
      renderQuestion(); }

    function buildFeedback(q, user) {
      document.getElementById('feedback-placeholder').style.display = 'none';
      const correct = q.correct;
      const isCorrect = (user === correct);
      document.getElementById('feedback-box').classList.add('visible', isCorrect ? 'correct' : 'wrong');
      document.getElementById('feedback-box').style.display = 'block';
      document.getElementById('badge-icon').textContent = isCorrect ? '✅' : '❌';
      document.getElementById('feedback-result-text').textContent = isCorrect ? 'Bonne réponse !' : 'Réponse incorrecte';
      let html = '';
      const parts = q.explication.split('\n\n');
      parts.forEach(part => {
        if (part.startsWith('✅')) html += `<div class="fb-section fb-correct"><strong>✅ Réponse</strong>${part.replace('✅ ','')}</div>`;
        else if (part.startsWith('🔍')) html += `<div class="fb-section fb-foundation"><strong>🔍 CORRECTION</strong>${part.replace('🔍 CORRECTION :','')}</div>`;
        else if (part.startsWith('⚠️')) html += `<div class="fb-section fb-obstacle"><strong>⚠️ VIGILANCE</strong>${part.replace('⚠️ VIGILANCE :','')}</div>`;
        else if (part.startsWith('💡')) html += `<div class="fb-section fb-tip"><strong>💡 ASTUCE</strong>${part.replace('💡 ASTUCE :','')}</div>`;
        else if (part.startsWith('🎯')) html += `<div class="fb-section fb-objectif"><strong>🎯 OBJECTIF</strong>${part.replace('🎯 OBJECTIF :','')}</div>`;
        else html += `<div class="fb-section">${part}</div>`;
      });
      document.getElementById('feedback-body').innerHTML = html;
      if (typeof renderMathInElement !== 'undefined') renderMathInElement(document.getElementById('feedback-body'), { delimiters: [{left:"$$",right:"$$",display:true},{left:"$",right:"$",display:false}], throwOnError: false });
    }

    function prevQuestion() { 
      if (currentQ > 0) { 
        currentQ--; 
        if(isQuestionLocked(currentQ) && !unlocked) {
          showUnlockModal();
          return;
        }
        renderQuestion(); 
        if (mode === 'exam') { perQSeconds = PER_Q_SEC; updatePerQTimerDisplay(); } 
      } 
    }
    
    function nextQuestion() { 
      let nextIndex = currentQ + 1;
      if(nextIndex < activeSet.length) {
        if(isQuestionLocked(nextIndex) && !unlocked) {
          showUnlockModal();
          return;
        }
        currentQ = nextIndex;
        renderQuestion(); 
        if (mode === 'exam') { perQSeconds = PER_Q_SEC; updatePerQTimerDisplay(); }
      } else { 
        if(!unlocked && activeSet.length === QUESTIONS_GRATUITES && activeSet.length < questionsData.length) {
          showUnlockModal();
        } else {
          finishQuiz();
        }
      } 
    }

    function finishQuiz() { if (examTimer) clearInterval(examTimer); if (perQTimer) clearInterval(perQTimer);
      document.body.classList.remove('exam-mode');
      showPage('page-results');
      let correctCount = 0;
      const themesMap = {};
      activeSet.forEach((idx, i) => {
        const q = questionsData[idx];
        const correct = q.correct;
        const ok = (userAnswers[i] === correct);
        if (ok) correctCount++;
        if (!themesMap[q.theme]) themesMap[q.theme] = { total: 0, correct: 0 };
        themesMap[q.theme].total++;
        if (ok) themesMap[q.theme].correct++;
      });
      const pct = Math.round(correctCount / activeSet.length * 100);
      document.getElementById('result-pct').textContent = pct + '%';
      document.getElementById('result-sub').textContent = `${correctCount} / ${activeSet.length} bonnes réponses`;
      document.getElementById('result-badge').textContent = pct >= 80 ? '🏆' : pct >= 50 ? '👍' : '💪';
      document.getElementById('result-themes').innerHTML = '<table class="result-table"><thead><tr><th>Thème</th><th>Score</th><th>%</th></tr></thead><tbody>' + Object.entries(themesMap).map(([theme, data]) => { const tp = Math.round(data.correct / data.total * 100); return `<tr><td>${tp>=80?'🟢':tp>=50?'🟡':'🔴'} ${theme}</td><td>${data.correct}/${data.total}</td><td>${tp}%</td>`; }).join('') + '</tbody></table>';
      const half = Math.ceil(activeSet.length / 2);
      let gridHtml = '<div class="grille-col" style="display:flex;flex-direction:column;gap:4px;">';
      for (let i = 0; i < half; i++) {
        const q = questionsData[activeSet[i]];
        const correct = q.correct;
        const user = userAnswers[i];
        gridHtml += `<div class="result-row"><span class="result-q-num">Q${q.id}</span>`;
        ['A','B','C','D'].forEach((ltr, j) => {
          let cls = '';
          if (correct === j && user === j) cls = 'correct-choice';
          else if (correct === j && user !== j) cls = 'missed-choice';
          else if (correct !== j && user === j) cls = 'wrong-choice';
          gridHtml += `<span class="result-case${cls?' '+cls:''}">${cls?ltr:''}</span>`;
        });
        gridHtml += '</div>';
      }
      gridHtml += '</div><div class="grille-col" style="display:flex;flex-direction:column;gap:4px;">';
      for (let i = half; i < activeSet.length; i++) {
        const q = questionsData[activeSet[i]];
        const correct = q.correct;
        const user = userAnswers[i];
        gridHtml += `<div class="result-row"><span class="result-q-num">Q${q.id}</span>`;
        ['A','B','C','D'].forEach((ltr, j) => {
          let cls = '';
          if (correct === j && user === j) cls = 'correct-choice';
          else if (correct === j && user !== j) cls = 'missed-choice';
          else if (correct !== j && user === j) cls = 'wrong-choice';
          gridHtml += `<span class="result-case${cls?' '+cls:''}">${cls?ltr:''}</span>`;
        });
        gridHtml += '</div>';
      }
      gridHtml += '</div>';
      document.getElementById('result-grid').innerHTML = gridHtml;
      document.getElementById('timer-wrap').classList.add('hidden');
      document.getElementById('perq-timer').classList.add('hidden');
    }

    function startExamTimer() { updateExamTimerDisplay();
      examTimer = setInterval(() => { examSeconds--; updateExamTimerDisplay(); if (examSeconds <= 0) { clearInterval(examTimer); clearInterval(perQTimer); finishQuiz(); } }, 1000); }
    function updateExamTimerDisplay() { const e = Math.floor(examSeconds / 60), t = examSeconds % 60, n = document.getElementById('timer-badge');
      n.textContent = `⏱ ${String(e).padStart(2,'0')}:${String(t).padStart(2,'0')}`;
      n.className = 'timer-badge'; if (examSeconds <= 600) n.classList.add('danger'); else if (examSeconds <= 1800) n.classList.add('warning'); }
    function startPerQTimer() { updatePerQTimerDisplay();
      perQTimer = setInterval(() => { perQSeconds--; updatePerQTimerDisplay(); if (perQSeconds <= 0) { clearInterval(perQTimer); validated[currentQ] = true; nextQuestion(); } }, 1000); }
    function updatePerQTimerDisplay() { const e = Math.floor(perQSeconds / 60), t = perQSeconds % 60, n = document.getElementById('perq-timer');
      n.textContent = `⚡ ${String(e).padStart(1,'0')}:${String(t).padStart(2,'0')}`;
      n.className = 'perq-timer'; if (perQSeconds <= 15) n.classList.add('danger'); else if (perQSeconds <= 30) n.classList.add('warning'); }

    document.addEventListener('keydown', e => { const page = document.querySelector('#main-app .page.active'); if (!page || page.id !== 'page-question') return;
      const key = e.key.toUpperCase();
      if (['A','B','C','D'].includes(key) && !validated[currentQ]) {
        userAnswers[currentQ] = ['A','B','C','D'].indexOf(key);
        renderQuestion(); if (mode === 'exam') buildGrilleExamen();
      }
      if (e.key === 'Enter' && mode === 'train') { const btn = document.getElementById('btn-validate'); if (!btn.disabled) validateAnswer(); }
      if (e.key === 'ArrowRight') nextQuestion();
      if (e.key === 'ArrowLeft') prevQuestion();
    });
  </script>
</body>
