    // ==================== 60 QUESTIONS — MASTER CAPES 2017 ====================
    const questionsData = [
      { id: 1, statement: "Dans une salle, il y a deux tables. La première dispose de 3 chaises numérotées de 1 à 3 et la seconde dispose de 5 chaises numérotées de 1 à 5. Le nombre de possibilités de distribuer 8 personnes autour de ces deux tables est :", choices: ["$C_8^3$", "$3!5!$", "$3!5!2!$", "$3!5!C_8^3$"], correct: 3, theme: "Dénombrement", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nOn choisit d'abord les 3 personnes qui s'assiéront à la première table : $C_8^3$ possibilités. Ensuite, on place ces 3 personnes sur les 3 chaises numérotées : $3!$ façons. On place les 5 personnes restantes sur les 5 chaises de la seconde table : $5!$ façons. Total : $C_8^3 \\times 3! \\times 5!$.\n\n⚠️ VIGILANCE : Ne pas oublier l'étape de choix des personnes pour chaque table avant de les permuter.\n\n💡 ASTUCE : On choisit d'abord qui va où, puis on permute sur chaque table.\n\n🎯 OBJECTIF : Appliquer le principe multiplicatif du dénombrement avec choix puis arrangement." },
      { id: 2, statement: "On pose pour tout $n \\in \\mathbb{N}^*$, $S_n = \\displaystyle\\sum_{k=0}^{n}\\left(C_n^k\\right)^2$.", choices: ["$S_n = C_{2n}^n$", "$S_n = \\left(\\dfrac{n(n+1)}{2}\\right)^2$", "$S_n = C_{2n}^{n+1}$", "$2^{2n}$"], correct: 0, theme: "Dénombrement — Identité de Vandermonde", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\nC'est l'identité de Vandermonde : $\\sum_{k=0}^{n} (C_n^k)^2 = C_{2n}^n$. Interprétation : choisir $n$ éléments parmi $2n$ = choisir $k$ parmi les $n$ premiers et $n-k$ parmi les $n$ derniers.\n\n⚠️ VIGILANCE : Ne pas confondre avec $\\sum C_n^k = 2^n$.\n\n💡 ASTUCE : $\\sum (C_n^k)^2 = C_{2n}^n$." },
      { id: 3, statement: "Le nombre de façons de ranger par matière et dans quatre boîtes distinctes, 4 livres de mathématiques, 5 livres d'économie, 2 de philosophies et 2 d'anglais est :", choices: ["$13!$", "$4!5!2!2!$", "$4!5!2!2!4!$", "$C_{13}^4 C_9^5 C_4^2 C_2^2$"], correct: 2, theme: "Dénombrement", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\nOn range par matière : les livres de chaque matière sont placés ensemble. Il y a $4!$ façons d'ordonner les 4 matières dans les 4 boîtes distinctes. Ensuite, à l'intérieur de chaque matière, on permute les livres : $4!$ pour les maths, $5!$ pour l'économie, $2!$ pour la philosophie, $2!$ pour l'anglais. Total : $4! \\times 4! \\times 5! \\times 2! \\times 2!$.\n\n⚠️ VIGILANCE : Ne pas oublier la permutation des matières entre elles.\n\n💡 ASTUCE : Ranger par matière = grouper puis ordonner les groupes et l'intérieur des groupes." },
      { id: 4, statement: "Soit $E$ un ensemble de cardinal $n$ non nul et $A$ une partie non vide de $E$ de cardinal $p$. Le nombre de parties de $E$ à $k$ éléments qui contiennent au moins un élément de $A$ est :", choices: ["$C_n^k C_{n-p}^{n-p}$", "$C_n^k - (n-p)$", "$C_n^k C_{n-p}^{k}$", "$C_n^k - C_{n-p}^k$"], correct: 3, theme: "Dénombrement", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\nNombre total de parties à $k$ éléments de $E$ : $C_n^k$. Nombre de parties à $k$ éléments ne contenant aucun élément de $A$ (donc contenues dans $E\\setminus A$, de cardinal $n-p$) : $C_{n-p}^k$. Par complémentarité, le nombre cherché est $C_n^k - C_{n-p}^k$.\n\n⚠️ VIGILANCE : « Au moins un » = Total − « Aucun ».\n\n💡 ASTUCE : Utiliser le passage au complémentaire en dénombrement." },
      { id: 5, statement: "Le nombre de façons de répartir $(n+1)$ boules dans $n$ boîtes sachant qu'aucune boîte n'est restée vide est :", choices: ["$n! C_{n+1}^2$", "$n^{n+1}$", "$n! n^{n+1}$", "$n^{n+1} - \\dfrac{n(n+1)}{2}$"], correct: 0, theme: "Dénombrement", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\nAucune boîte vide signifie que chaque boîte reçoit au moins une boule. Avec $n+1$ boules et $n$ boîtes, une boîte recevra exactement 2 boules, les autres 1 boule. On choisit d'abord les 2 boules qui iront ensemble : $C_{n+1}^2$ possibilités. On a alors $n$ « objets » (1 paquet de 2 boules + $n-1$ boules seules) à répartir dans $n$ boîtes distinctes, soit $n!$ façons. Total : $n! \\times C_{n+1}^2$.\n\n⚠️ VIGILANCE : Avec $n+1$ boules et $n$ boîtes sans boîte vide, il y a forcément une boîte avec 2 boules.\n\n💡 ASTUCE : On choisit les 2 boules qui seront ensemble, puis on permute les $n$ paquets." },
      { id: 6, statement: "Pour tous entiers naturels $p$ et $n$ tels que $1 \\le p \\le n-1$, on pose $S = C_{n-1}^p + C_{n-1}^{p-1}$. Alors :", choices: ["$S = C_{n+1}^p$", "$S = C_n^{p+1}$", "$S = C_n^p$", "$S = p C_n^p$"], correct: 2, theme: "Dénombrement — Triangle de Pascal", niveau_scolaire: "Master", explication: "✅ Réponse : C\n\n🔍 CORRECTION :\nC'est la formule du triangle de Pascal : $C_{n-1}^p + C_{n-1}^{p-1} = C_n^p$. Elle se démontre combinatoirement : choisir $p$ éléments parmi $n$ = soit prendre le $n$-ième élément (il reste $p-1$ à choisir parmi $n-1$), soit ne pas le prendre (il reste $p$ à choisir parmi $n-1$).\n\n⚠️ VIGILANCE : Attention aux indices : $C_{n-1}^p + C_{n-1}^{p-1} = C_n^p$.\n\n💡 ASTUCE : Visualiser le triangle de Pascal : chaque coefficient est la somme des deux au-dessus." },
      { id: 7, statement: "On lance 60 fois de suite d'une manière indépendante un dé truqué dont la probabilité d'apparition de la face 6 vaut $p$. Soit $X$ l'aléa numérique qui prend pour valeur le nombre d'apparition de la face 6. La valeur de $p$ pour que la variance de la loi $X$ soit égale à 15 est :", choices: ["$\\dfrac{1}{4}$", "$\\dfrac{1}{2}$", "$\\dfrac{1}{6}$", "$\\dfrac{1}{8}$"], correct: 1, theme: "Probabilités — Loi binomiale", niveau_scolaire: "Master", explication: "✅ Réponse : B\n\n🔍 CORRECTION :\n$X \\sim B(60, p)$. $V(X) = np(1-p) = 60p(1-p) = 15$. $60p - 60p^2 = 15$, $4p^2 - 4p + 1 = 0$, $(2p-1)^2 = 0$, $p = 1/2$.\n\n⚠️ VIGILANCE : Ne pas confondre variance $np(1-p)$ et écart-type.\n\n💡 ASTUCE : $60p(1-p)=15$ → $4p(1-p)=1$ → $4p^2-4p+1=0$." },
      { id: 8, statement: "Un appareil de mesure évalue l'épaisseur en mm de pièces mécaniques. L'expérience prouve que l'épaisseur des pièces peut être modélisée par une variable aléatoire $X$ qui suit la loi uniforme dans l'intervalle $[0, 10]$.", choices: ["$X$ a pour densité $f(t) = \\dfrac{1}{2}$", "$P(X = 5) = \\dfrac{1}{2}$", "$P(5 \\le X \\le 6) = \\dfrac{1}{5}$", "$P(X \\ge 5) = \\dfrac{1}{2}$"], correct: 3, theme: "Probabilités — Loi uniforme", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$X \\sim \\mathcal{U}([0,10])$. Densité $f(t)=1/10$ (A faux). $P(X=5)=0$ (B faux). $P(5\\le X\\le6)=1/10$ (C faux). $P(X\\ge5)=5/10=1/2$ (D vrai).\n\n⚠️ VIGILANCE : Pour une loi continue, $P(X=c)=0$.\n\n💡 ASTUCE : $P(a\\le X\\le b) = (b-a)/10$." },
      { id: 9, statement: "Soit $X$ une variable aléatoire qui suit la loi uniforme sur $[0, 1]$. $P_{(X>0{,}3)}(X > 0{,}6)$ est égale à :", choices: ["$\\dfrac{6}{10}$", "$\\dfrac{3}{6}$", "$\\dfrac{3}{10}$", "$\\dfrac{4}{7}$"], correct: 3, theme: "Probabilités conditionnelles", niveau_scolaire: "Master", explication: "✅ Réponse : D\n\n🔍 CORRECTION :\n$P_{(X>0,3)}(X>0,6) = \\frac{P(X>0,6 \\cap X>0,3)}{P(X>0,3)} = \\frac{P(X>0,6)}{P(X>0,3)} = \\frac{1-0,6}{1-0,3} = \\frac{0,4}{0,7} = \\frac{4}{7}$.\n\n⚠️ VIGILANCE : $\\{X>0,6\\} \\subset \\{X>0,3\\}$.\n\n💡 ASTUCE : Pour une loi uniforme, $P(X>a)=1-a$." },
      { id: 10, statement: "On dispose d'un dé parfait dont les faces sont numérotées de 1 à 6. On lance ce dé $n$ fois de suite d'une manière indépendante ($n \\ge 2$). La probabilité de réaliser une seule fois la face 6 est :", choices: ["$n\\dfrac{5^{n-1}}{6^n}$", "$\\dfrac{1}{6}\\left(\\dfrac{5}{6}\\right)^{n-1}$", "$1 - \\left(\\dfrac{5}{6}\\right)^{n-1}$", "$1 - \\left(\\dfrac{5}{6}\\right)^n$"], correct: 0, theme: "Probabilités — Loi binomiale", niveau_scolaire: "Master", explication: "✅ Réponse : A\n\n🔍 CORRECTION :\n$X \\sim B(n, 1/6)$. $P(X=1) = C_n^1 (1/6)^1 (5/6)^{n-1} = n \\cdot \\frac{1}{6} \\cdot \\frac{5^{n-1}}{6^{n-1}} = n \\frac{5^{n-1}}{6^n}$.\n\n⚠️ VIGILANCE : Ne pas oublier le coefficient binomial $C_n^1 = n$.\n\n💡 ASTUCE : $P(X=k) = C_n^k p^k (1-p)^{n-k}$." }
    ];
